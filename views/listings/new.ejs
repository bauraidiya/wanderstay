<% layout("/layouts/boilerplate.ejs") %>
<div class="row">
    <div class="col-8 offset-2">
    <h3>Create a New Listing</h3>
    <div>
        <form method="post" action="/listing">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input type="text" name="Listing[title]" placeholder="Enter title name" class="form-control">
            </div>
           
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea type="text" name="Listing[description]" placeholder="Write Description here" class="form-control"></textarea>  
            </div>
            
            <div class="mb-3">
                <label for="image" class="form-label">Image</label>
                <input type="text" name="Listing[image[url]]" placeholder="Write image url/link here " class="form-control">
            </div>
           
            <div class="row">
             <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price</label>
                <input type="number" name="Listing[price]" placeholder="Ex: 1200" class="form-control">
             </div>

              <div class="mb-3 col-md-8">
                <label for="country" class="form-label">Country</label>
                <input type="text" name="Listing[country]" placeholder="Ex:- India" class="form-control">
              </div>
            </div>
          
            <div class="mb-3">
                <label for="location" class="form-label">Location</label>
                <input type="text" name="Listing[location]" placeholder="Ex:- Dehradun, Uttarakhand" class="form-control" >
            </div>
            
           
            
            <button class="Add-btn btn-dark mb-3">Add</button>
        </form>
    </div>
    </div>
</div>
